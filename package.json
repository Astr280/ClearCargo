{
  "name": "cargoclear",
  "private": true,
  "version": "1.0.0",
  "description": "CargoClear freight forwarding platform starter",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @cargoclear/web",
    "dev:api": "npm run dev --workspace @cargoclear/api",
    "build:web": "npm run build --workspace @cargoclear/web",
    "build:api": "npm run build --workspace @cargoclear/api",
    "build": "npm run build:web && npm run build:api"
  }
}
